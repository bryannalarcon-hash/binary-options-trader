# =============================================================================
# Meridian — Environment configuration template
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in each value.
# Variables grouped by which component needs them.
# Comments under each var explain WHERE to get the value.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Solana network configuration
# -----------------------------------------------------------------------------

# RPC endpoint Meridian connects to. Devnet for core submission; mainnet-beta only for bonus deploy.
# Free devnet: https://api.devnet.solana.com  (rate-limited; OK for development)
# Better devnet: https://devnet.helius-rpc.com/?api-key=YOUR_KEY  (sign up at helius.dev for free tier)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Network identifier — used by frontend wallet adapter and Anchor.
# Valid: devnet | mainnet-beta | testnet | localnet
SOLANA_CLUSTER=devnet

# Used by Anchor CLI for deploys / tests. Usually mirrors SOLANA_RPC_URL.
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com


# -----------------------------------------------------------------------------
# 2. Wallets / keypairs
# -----------------------------------------------------------------------------

# Path to your local Solana CLI keypair (used by Anchor for deploys).
# Generate with: solana-keygen new --outfile ~/.config/solana/id.json
# Fund on devnet with: solana airdrop 2 --url devnet
ANCHOR_WALLET=/home/bryann/.config/solana/id.json

# Path to the keypair that will be the ADMIN authority on the deployed Meridian program.
# This wallet can: pause/unpause, admin_settle_override, add_strike.
# Generate a NEW keypair specifically for this; do NOT reuse your dev wallet.
# Generate: solana-keygen new --outfile ./keys/admin.json --no-bip39-passphrase
ADMIN_KEYPAIR_PATH=./keys/admin.json
ADMIN_PUBKEY=                                # paste output of: solana-keygen pubkey ./keys/admin.json

# Path to the keypair the automation service signs with.
# Needs SOL to pay for create_strike_market and settle_market transactions every day.
# Generate: solana-keygen new --outfile ./keys/automation.json --no-bip39-passphrase
# Fund: solana airdrop 2 <pubkey> --url devnet
AUTOMATION_KEYPAIR_PATH=./keys/automation.json
AUTOMATION_PUBKEY=                           # paste output of: solana-keygen pubkey ./keys/automation.json

# Where fees collected by Meridian go. MUST be different from the vault accounts.
# Create a fresh keypair OR use a wallet pubkey you control.
FEE_DESTINATION_PUBKEY=


# -----------------------------------------------------------------------------
# 3. Program IDs
# -----------------------------------------------------------------------------

# Filled in AFTER first `anchor deploy`. Anchor will write it to target/idl too.
# On first run leave blank — the deploy script writes it back.
MERIDIAN_PROGRAM_ID=

# Phoenix V1 mainnet program ID (same across all clusters where Phoenix is deployed).
# VERIFY THIS BEFORE BUILD — Phoenix may not be deployed on devnet. If absent, see blocker #2 in the plan.
PHOENIX_PROGRAM_ID=PhoeNiXZ8ByJGLkxNfZRnkUfjvmuYqLR89jjFHGqdXY

# SPL Token program (constant — same on every Solana cluster).
SPL_TOKEN_PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA

# Associated Token Account program (constant).
ATA_PROGRAM_ID=ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL


# -----------------------------------------------------------------------------
# 4. USDC mint address
# -----------------------------------------------------------------------------

# Devnet USDC (commonly used by Solana DeFi tutorials). Verify before depending on it.
# Devnet USDC: Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr  (community-deployed)
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr


# -----------------------------------------------------------------------------
# 5. Pyth Network feed IDs (one per MAG7 ticker)
# -----------------------------------------------------------------------------
# Get the live feed ID for each ticker from: https://pyth.network/price-feeds
# Look up "Equity.US.<TICKER>/USD" — they're 32-byte hex strings starting with 0x
# VERIFY EACH FEED EXISTS ON DEVNET — see blocker #1 in plan.
# If a feed is missing, fall back to Switchboard or mock for devnet.

PYTH_FEED_AAPL=                              # AAPL/USD price account on Solana (PriceUpdateV2)
PYTH_FEED_MSFT=                              # MSFT/USD
PYTH_FEED_GOOGL=                             # GOOGL/USD
PYTH_FEED_AMZN=                              # AMZN/USD
PYTH_FEED_NVDA=                              # NVDA/USD
PYTH_FEED_META=                              # META/USD
PYTH_FEED_TSLA=                              # TSLA/USD

# Pyth Solana Receiver program ID (constant per cluster).
# Mainnet: rec5EKMGg6MxZYaMdyBfgwp4d5rB9T1VQH5pJv5LtFJ
# Devnet:  same as mainnet (Pyth ships the same program to all clusters)
PYTH_RECEIVER_PROGRAM_ID=rec5EKMGg6MxZYaMdyBfgwp4d5rB9T1VQH5pJv5LtFJ

# Pyth Hermes endpoint — used by automation service to fetch latest signed prices off-chain
# (then posts them on-chain via the Receiver right before settlement).
PYTH_HERMES_URL=https://hermes.pyth.network

# Oracle freshness window in seconds. PRD allows configuration; default ~30s for settlement.
ORACLE_MAX_STALENESS_SECONDS=30

# Maximum acceptable confidence interval as a fraction of price. 0.005 = ±0.5%.
ORACLE_MAX_CONFIDENCE_RATIO=0.005


# -----------------------------------------------------------------------------
# 6. Switchboard fallback (optional)
# -----------------------------------------------------------------------------

# Used only if Pyth fails. Get feeds from https://app.switchboard.xyz/solana/devnet
SWITCHBOARD_PROGRAM_ID=SW1TCH7qEPTdLsDHRgPuMQjbQxKdH2aBStViMFnt64f
SWITCHBOARD_FEED_AAPL=
SWITCHBOARD_FEED_MSFT=
# ... (add per ticker as needed)


# -----------------------------------------------------------------------------
# 7. Automation service config
# -----------------------------------------------------------------------------

# Cron expressions are evaluated in AUTOMATION_CRON_TIMEZONE (below), so write them
# as wall-clock ET — no UTC conversion, and DST is handled automatically.
# Morning job (creates strikes): 8:00 AM ET (before the 9:30 open).
AUTOMATION_MORNING_CRON=0 8 * * 1-5

# Settlement job: 4:05 PM ET (just after the 4:00 close).
AUTOMATION_SETTLE_CRON=5 16 * * 1-5

# IANA timezone the crons above run in. Pin to ET so schedules are DST-correct
# and identical across UTC/non-UTC hosts (Railway containers run UTC).
AUTOMATION_CRON_TIMEZONE=America/New_York

# How many seconds to wait between settle_market retries when oracle confidence is too wide.
AUTOMATION_SETTLE_RETRY_INTERVAL=30

# Max retry duration before alerting admin (seconds). PRD says ~15 minutes.
AUTOMATION_SETTLE_MAX_RETRY_SECONDS=900

# NYSE trading calendar source — automation must skip non-trading days.
# Option A: polygon.io free tier — set POLYGON_API_KEY
# Option B: hardcoded JSON of US market holidays maintained in repo
# Option C: nyse-trading-days npm package (community-maintained)
NYSE_CALENDAR_SOURCE=hardcoded               # values: polygon | nyse-trading-days | hardcoded
POLYGON_API_KEY=

# Webhook for ops alerts (failed settlement, oracle outage, etc.). Optional.
ALERT_WEBHOOK_URL=                           # e.g., Discord/Slack/PagerDuty webhook


# -----------------------------------------------------------------------------
# 8. Frontend (Next.js) — these are exposed to the browser if prefixed NEXT_PUBLIC_
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_MERIDIAN_PROGRAM_ID=             # mirror MERIDIAN_PROGRAM_ID after deploy
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
NEXT_PUBLIC_PHOENIX_PROGRAM_ID=PhoeNiXZ8ByJGLkxNfZRnkUfjvmuYqLR89jjFHGqdXY

# Optional: app metadata for wallet connect screens
NEXT_PUBLIC_APP_NAME=Meridian
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 9. Observability (optional, recommended for bonus mainnet deploy)
# -----------------------------------------------------------------------------

SENTRY_DSN=                                   # crash reporting; sentry.io
LOG_LEVEL=info                                # trace | debug | info | warn | error
LOG_FORMAT=json                               # json | pretty


# -----------------------------------------------------------------------------
# 10. Development toggles
# -----------------------------------------------------------------------------

# When true, automation runs the oracle updater job: it pulls live Pyth Hermes
# prices and writes them on-chain via update_oracle.
# (Legacy name: USE_MOCK_ORACLE — still honoured for backward-compat if unset.)
USE_HERMES_ORACLE=false

# When true, automation skips real market-day calendar and creates markets every run.
# Useful for local devnet integration testing.
SKIP_CALENDAR_CHECK=false

# When true, settle_market can be called immediately after market creation (no time gate).
# Used only in unit tests.
TEST_BYPASS_TIME_GATE=false
