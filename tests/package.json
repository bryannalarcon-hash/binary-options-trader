{
  "name": "tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test:unit": "mocha -t 60000 'unit/**/*.test.ts'",
    "test:anchor": "mocha -t 1000000 anchor/**/*.test.ts",
    "test:anchor:integration": "mocha -t 1000000 anchor/integration.test.ts",
    "test:anchor:edge": "mocha -t 1000000 anchor/edge-cases.test.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:auto": "E2E_AUTOSTART=1 playwright test --config e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit -p ."
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.30.1",
    "@playwright/test": "^1.49.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.9.0",
    "bn.js": "^5.2.1",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "mocha": {
    "require": "ts-node/register",
    "extensions": ["ts"]
  }
}
